# Local compression backups and temp artifacts — keep on disk, not in repo.
*.bak
*._compressed.png
*._compressed.mp4

# Large PNG masters — the site now serves the generated .webp/.jpg instead, so
# the masters stay local and out of git. Re-run scripts/compress-portfolio-media.ps1
# after replacing one. (Masters committed before this change remain tracked until
# removed with: git rm --cached bill/assets/portfolio/*.png)
*.png

